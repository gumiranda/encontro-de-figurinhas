{
  "name": "@workspace/backend",
  "type": "module",
  "scripts": {
    "dev": "convex dev --env-file .env.local",
    "dev:env-dev": "convex dev --env-file .env.dev",
    "dev:env-prod": "convex dev --env-file .env.prod",
    "setup": "convex dev --until-success --env-file .env.local",
    "seed:cities": "convex run seeds/seedCities:seedCities",
    "seed:tradepoints": "convex run seeds/seedTradePoints:seedTradePoints",
    "seed:blog": "convex run seedBlog:seedBlogPosts",
    "seed:all": "pnpm seed:cities && pnpm seed:tradepoints",
    "seed:album:dashboard": "echo 'Run seedAlbumConfig from Convex dashboard (requires admin auth)'"
  },
  "exports": {
    "./convex": "./convex/*.ts",
    "./convex/matches": "./convex/matches.ts",
    "./convex/trades": "./convex/trades.ts",
    "./_generated/api": "./convex/_generated/api.js",
    "./_generated/dataModel": "./convex/_generated/dataModel.d.ts",
    "./lib/types": "./convex/lib/types.ts",
    "./lib/ipLocationToken": "./convex/lib/ipLocationToken.ts",
    "./lib/setLocationErrors": "./convex/lib/setLocationErrors.ts",
    "./lib/geo": "./convex/lib/geo.ts",
    "./lib/confidence-status": "./convex/lib/confidence_status.ts",
    "./lib/report-severity": "./convex/lib/report_severity.ts"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "latest"
  },
  "dependencies": {
    "@clerk/backend": "^2.10.1",
    "@convex-dev/rate-limiter": "^0.3.2",
    "convex": "1.25.4",
    "convex-helpers": "^0.1.104",
    "crypto": "^1.0.1",
    "zod": "^3.25.76"
  }
}
